---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Marketing strategy, execution, and support." } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href={`${import.meta.env.BASE_URL}/favicon.ico`} sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL}/favicon-32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${import.meta.env.BASE_URL}/favicon-16.png`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}/apple-touch-icon.png`} />
    <meta name="description" content={description} />
    <title>{title} · Vandalist</title>
  </head>
  <body class="bg-white text-[var(--color-ink)] antialiased">
    <div class="pt-1.5 pl-1.5 pr-1.5 md:pt-2 md:pl-2 md:pr-2">
      <slot />
    </div>
  </body>
</html>
