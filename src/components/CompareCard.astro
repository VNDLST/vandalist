---
const weAre = [
  "Structured marketing partner",
  "Specialist team",
  "Practical execution",
  "Flexible support",
];
const weArent = [
  "Freelancer substitute",
  "Strategy-only consultancy",
  "Project-only design studio",
  "Full internal department",
];
---
<section class="max-w-6xl mx-auto px-6 md:px-10 py-16 md:py-24">
  <div class="rounded-[var(--radius-card)] bg-[var(--color-paper-dim)] p-6 md:p-10">
    <div class="bg-white rounded-[var(--radius-card)] shadow-[0_12px_32px_-12px_rgba(28,27,26,0.12)] grid md:grid-cols-2 md:divide-x divide-[var(--color-line)] overflow-hidden">
      <div class="p-8 md:p-12">
        <div class="flex items-center gap-4 mb-6">
          <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="#7fb88a" stroke-width="2.25" class="shrink-0">
            <circle cx="12" cy="11.5" r="9.5" />
            <path d="M7 12 L10.5 15.5 L18.5 5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <h3 class="text-xl font-semibold text-[var(--color-ink)]">We are&hellip;</h3>
        </div>
        <ul class="divide-y divide-[var(--color-line)]">
          {weAre.map((item) => (
            <li class="py-3 text-[var(--color-slate)]">{item}</li>
          ))}
        </ul>
      </div>
      <div class="p-8 md:p-12">
        <div class="flex items-center gap-4 mb-6">
          <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.25" class="shrink-0">
            <circle cx="12" cy="12" r="9.5" />
            <path d="M7.5 7.5 L18.5 18.5 M18.5 5 L7 17" stroke-linecap="round" />
          </svg>
          <h3 class="text-xl font-semibold text-[var(--color-ink)]">Not so much&hellip;</h3>
        </div>
        <ul class="divide-y divide-[var(--color-line)]">
          {weArent.map((item) => (
            <li class="py-3 text-[var(--color-slate)]">{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

