---
import IconBadge from "./IconBadge.astro";

const weAre = [
  "Structured marketing partner",
  "Specialist team",
  "Practical execution",
  "Flexible support",
];
const weArent = [
  "Freelancer substitute",
  "Strategy-only consultancy",
  "Project-only design studio",
  "Full internal department",
];
---
<section class="max-w-5xl mx-auto px-6 md:px-10 py-16 md:py-24">
  <div class="border border-[var(--color-line)] rounded-[var(--radius-card)] p-8 md:p-12 grid md:grid-cols-2 gap-10 md:gap-16">
    <div>
      <h3 class="text-lg font-semibold mb-6">We Are</h3>
      <ul class="space-y-4">
        {weAre.map((item) => (
          <li class="flex items-center gap-3 text-[var(--color-ink)]">
            <IconBadge variant="good" />
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
    <div>
      <h3 class="text-lg font-semibold mb-6">Not So Much</h3>
      <ul class="space-y-4">
        {weArent.map((item) => (
          <li class="flex items-center gap-3 text-[var(--color-slate)]">
            <IconBadge variant="bad" />
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
