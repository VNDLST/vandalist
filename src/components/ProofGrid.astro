---
// PLACEHOLDER CARD IMAGES — stand-ins for real case-study photography/screens
// shown in mockup6 (team photo, site screenshot, product shot, dashboard shot).
// Swap the <svg> per `kind` for real photos once available.
import ProofCardImage from "./ProofCardImage.astro";

const items: { kind: Parameters<typeof ProofCardImage>[0]["kind"]; name: string; text: string }[] = [
  { kind: "meeting", name: "Kestrel Health", text: "Repositioned the brand and built a lead engine that drove a 42% increase in qualified opportunities." },
  { kind: "website", name: "Harwood Interiors", text: "Modernized the website and launched campaigns that grew traffic by 86% in 6 months." },
  { kind: "product", name: "Nourish Beauty", text: "Built a full-funnel strategy and email flows that increased revenue by 35% quarter over quarter." },
  { kind: "dashboard", name: "Motion Systems", text: "Implemented a reporting system that improved marketing ROI visibility by 60%." },
];
---
<section class="max-w-5xl mx-auto px-6 md:px-10 pt-4 md:pt-6 pb-16 md:pb-24">
  <p class="text-sm uppercase tracking-wide font-semibold text-[var(--color-ink)] mb-6">Proof in Practice</p>
  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {items.map((item) => (
      <div class="flex flex-col">
        <ProofCardImage kind={item.kind} />
        <div class="pt-4">
          <p class="font-semibold text-[var(--color-ink)] text-sm mb-1">{item.name}</p>
          <p class="text-[var(--color-slate)] text-sm leading-relaxed mb-3">{item.text}</p>
          <a href="#" class="text-[var(--color-accent)] text-sm font-medium inline-flex items-center gap-1">
            View case study <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    ))}
  </div>
</section>
