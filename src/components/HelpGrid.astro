---
import GradientIcon from "./GradientIcon.astro";

const items: { icon: Parameters<typeof GradientIcon>[0]["icon"]; text: string }[] = [
  { icon: "message", text: "Refining messaging, positioning, and campaign direction." },
  { icon: "layout", text: "Producing and improving websites, marketing assets, and content." },
  { icon: "megaphone", text: "Supporting campaigns, launches, and ongoing marketing activity." },
  { icon: "settings", text: "Implementing marketing systems, reporting, and automation." },
  { icon: "wrench", text: "Solving practical marketing problems as they arise." },
  { icon: "unlock", text: "Providing access to the skills needed when internal capacity is limited." },
];
---
<section class="max-w-5xl mx-auto px-6 md:px-10 py-16 md:py-24">
  <div class="mb-12 max-w-2xl">
    <p class="text-sm uppercase tracking-wide text-[var(--color-accent)] font-medium mb-3">How We Help in Practice</p>
    <h2 class="text-2xl md:text-3xl font-semibold mb-4">Marketing rarely arrives as a neat, isolated project.</h2>
    <p class="text-[var(--color-slate)]">
      Most of the time it's a mix of planning, building, improving, and responding to opportunities as they appear.
    </p>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {items.map((item) => (
      <div class="rounded-[var(--radius-card)] border border-[var(--color-line)] bg-[var(--color-paper-dim)] p-6 flex flex-col gap-4">
        <GradientIcon icon={item.icon} />
        <p class="text-[var(--color-ink)] text-sm leading-relaxed">{item.text}</p>
      </div>
    ))}
  </div>

  <p class="mt-10 text-[var(--color-slate)] text-sm max-w-xl">
    Some work is planned, some appears unexpectedly — the important thing is having the capability to keep it moving.
  </p>
</section>
