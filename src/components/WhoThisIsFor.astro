---
import GradientIcon from "./GradientIcon.astro";

const items: { icon: Parameters<typeof GradientIcon>[0]["icon"]; text: string }[] = [
  { icon: "message", text: "Need consistent, reliable marketing capability" },
  { icon: "layout", text: "Have marketing work to execute but limited internal capacity" },
  { icon: "megaphone", text: "Want practical strategy alongside execution" },
  { icon: "settings", text: "Can make decisions without excessive delay" },
  { icon: "wrench", text: "Have marketing priorities that change throughout the year" },
  { icon: "unlock", text: "Need support that can scale up or down as required" },
];
---
<section class="max-w-5xl mx-auto px-6 md:px-10 py-16 md:py-24">
  <div class="mb-12 max-w-2xl">
    <p class="text-sm uppercase tracking-wide text-[var(--color-accent)] font-medium mb-3">Who This Is Best For</p>
    <h2 class="text-2xl md:text-3xl font-semibold">For organisations that:</h2>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {items.map((item) => (
      <div class="aspect-square rounded-[var(--radius-card)] bg-white shadow-[0_12px_32px_-12px_rgba(28,27,26,0.12)] p-6 flex flex-col items-center justify-center text-center gap-4">
        <GradientIcon icon={item.icon} />
        <p class="text-[var(--color-ink)] text-sm leading-relaxed">{item.text}</p>
      </div>
    ))}
  </div>
</section>
