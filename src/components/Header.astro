---
const leftLinks = [
  { label: "Services", href: "/services" },
  { label: "Work", href: "/work" },
  { label: "Case Studies", href: "/case-studies" },
];
const rightLinks = [
  { label: "How We Work", href: "/how-we-work" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];
---
<header class="w-full py-6 px-6 md:px-10">
  <nav class="max-w-6xl mx-auto flex items-center justify-between gap-4">
    <ul class="hidden md:flex items-center gap-6 text-sm text-[var(--color-slate)] flex-1">
      {leftLinks.map((link) => (
        <li><a href={link.href} class="hover:text-[var(--color-ink)] transition-colors">{link.label}</a></li>
      ))}
    </ul>

    <a href="/" class="font-display text-lg font-semibold tracking-tight shrink-0">
      Vandalist
    </a>

    <ul class="hidden md:flex items-center gap-6 text-sm text-[var(--color-slate)] flex-1 justify-end">
      {rightLinks.map((link) => (
        <li><a href={link.href} class="hover:text-[var(--color-ink)] transition-colors">{link.label}</a></li>
      ))}
    </ul>

    <!-- mobile: simple stacked link row, no hamburger complexity for v1 -->
    <ul class="flex md:hidden items-center gap-3 text-xs text-[var(--color-slate)] overflow-x-auto">
      {[...leftLinks, ...rightLinks].map((link) => (
        <li class="shrink-0"><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
  </nav>
</header>
