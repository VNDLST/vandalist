---
interface Props {
  kind: "strategy" | "content" | "campaigns" | "insight" | "automation" | "support";
}
const { kind } = Astro.props as Props;
---
<div class="w-full aspect-[4/3] rounded-xl bg-[var(--color-paper-dim)] border border-[var(--color-line)] flex items-center justify-center overflow-hidden">
  {kind === "strategy" && (
    <svg width="72" height="72" viewBox="0 0 72 72" fill="none" stroke="var(--color-ink)" stroke-width="1.5">
      <circle cx="34" cy="40" r="16" />
      <circle cx="34" cy="40" r="9" />
      <circle cx="34" cy="40" r="2.5" fill="var(--color-ink)" stroke="none" />
      <path d="M46 16 L34 40" stroke-linecap="round" />
      <path d="M46 16 l-7 1 M46 16 l1 7" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )}
  {kind === "content" && (
    <svg width="76" height="76" viewBox="0 0 76 76" fill="none" stroke="var(--color-ink)" stroke-width="1.5">
      <rect x="14" y="16" width="48" height="32" rx="2" />
      <circle cx="30" cy="30" r="5" />
      <path d="M14 42 L26 32 L36 40 L48 26 L62 40" stroke-linejoin="round" stroke-linecap="round" />
      <path d="M28 54 h20" stroke-linecap="round" />
      <path d="M34 48 v6 M42 48 v6" />
    </svg>
  )}
  {kind === "campaigns" && (
    <svg width="76" height="76" viewBox="0 0 76 76" fill="none" stroke="var(--color-ink)" stroke-width="1.5">
      <rect x="14" y="28" width="22" height="22" rx="1.5" />
      <path d="M14 34 h22" />
      <path d="M25 28 v-4 l4 4 l-4 4 l-4 -4 z" stroke-linejoin="round" />
      <rect x="40" y="20" width="22" height="30" rx="1.5" />
      <path d="M40 27 h22" stroke-dasharray="2 2" />
    </svg>
  )}
  {kind === "insight" && (
    <svg width="72" height="72" viewBox="0 0 72 72" fill="none" stroke="var(--color-ink)" stroke-width="1.5">
      <circle cx="32" cy="32" r="15" />
      <path d="M43 43 L58 58" stroke-linecap="round" />
      <path d="M25 32 h14 M32 25 v14" stroke-linecap="round" />
    </svg>
  )}
  {kind === "automation" && (
    <svg width="76" height="76" viewBox="0 0 76 76" fill="none" stroke="var(--color-ink)" stroke-width="1.5">
      <circle cx="27" cy="30" r="14" />
      <path d="M27 16 A14 14 0 0 1 41 30 L27 30 Z" fill="var(--color-accent)" stroke="none" opacity="0.55" />
      <path d="M46 52 v-16 M54 52 v-24 M62 52 v-9" stroke-linecap="round" />
      <path d="M42 52 h24" stroke-linecap="round" />
    </svg>
  )}
  {kind === "support" && (
    <svg width="76" height="76" viewBox="0 0 76 76" fill="none" stroke="var(--color-ink)" stroke-width="1.5">
      <path d="M16 24 h32 a4 4 0 0 1 4 4 v14 a4 4 0 0 1 -4 4 h-16 l-8 8 v-8 h-8 a4 4 0 0 1 -4 -4 v-14 a4 4 0 0 1 4 -4 z" stroke-linejoin="round" />
      <path d="M28 46 h28 a4 4 0 0 0 4 -4 v-8" stroke-dasharray="2 2" />
    </svg>
  )}
</div>
