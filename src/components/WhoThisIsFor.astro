---
import SectionHeading from "./SectionHeading.astro";

// Real client-supplied thumbnails swapped in where available.
// "Post-transaction or new brand" (puzzle piece) image is still pending —
// keep its flat color swatch until that asset arrives.
const items = [
  { image: "growth-stage", title: "Growth-stage companies", text: "Scaling fast and needing marketing that keeps up." },
  { image: "lean-marketing", title: "In-house lean marketing teams", text: "Need extra hands, expertise, or fresh perspective." },
  { image: "strategic-refresh", title: "Strategic refresh moment", text: "Repositioning, refining messaging, or entering new markets." },
  { color: "#d9cfc0", title: "Post-transaction or new brand", text: "Need to align, integrate, and move forward fast." },
  { image: "performance-improvement", title: "Performance improvement", text: "Looking to drive stronger results from marketing." },
  { image: "support-network", title: "In-house teams needing support", text: "Specialized expertise without the overhead of full-time hires." },
];
---
<section class="max-w-7xl mx-auto px-6 md:px-10 py-16 md:py-24">
  <SectionHeading
    eyebrow="Who this is best for"
    heading="The right amount of Vandalist"
    subtext="For organisations that need marketing capability without the weight of an internal team."
  />

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {items.map((item) => (
      <div class="rounded-[var(--radius-card)] border border-[var(--color-line)] bg-white overflow-hidden flex h-full">
        {item.image ? (
          <img
            src={`${import.meta.env.BASE_URL}/who-icons/${item.image}.webp`}
            alt=""
            class="w-[38%] shrink-0 object-cover"
          />
        ) : (
          <div class="w-[38%] shrink-0" style={`background:${item.color}`}></div>
        )}
        <div class="p-5 flex flex-col justify-center">
          <h3 class="text-[var(--color-ink)] font-semibold mb-1 text-sm">{item.title}</h3>
          <p class="text-[var(--color-slate)] text-sm leading-relaxed">{item.text}</p>
        </div>
      </div>
    ))}
  </div>
</section>
