---
const leftLinks = [
  { label: "Services", href: "/services" },
  { label: "Work", href: "/work" },
  { label: "Case Studies", href: "/case-studies" },
];
const rightLinks = [
  { label: "How We Work", href: "/how-we-work" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];
---
<header class="w-full py-8 md:py-10 px-6 md:px-10">
  <nav class="max-w-6xl mx-auto flex items-center justify-center gap-8 md:gap-16">
    <ul class="hidden md:flex items-center gap-6 text-sm text-[var(--color-slate)]">
      {leftLinks.map((link, i) => (
        <li>
          <a href={link.href} class="hover:text-[var(--color-ink)] transition-colors">{link.label}</a>
          {i === 0 && (
            <svg width="24" height="6" viewBox="0 0 24 6" class="mt-1" aria-hidden="true">
              <line x1="1" y1="3" x2="23" y2="3" stroke="var(--color-accent)" stroke-width="1.5" stroke-dasharray="3 3" stroke-linecap="round" />
            </svg>
          )}
        </li>
      ))}
    </ul>

    <a href="/" class="shrink-0">
      <img src={`${import.meta.env.BASE_URL}/vandalist-logo.png`} alt="Vandalist" class="h-16 md:h-20 w-auto" />
    </a>

    <ul class="hidden md:flex items-center gap-6 text-sm text-[var(--color-slate)]">
      {rightLinks.map((link) => (
        <li><a href={link.href} class="hover:text-[var(--color-ink)] transition-colors">{link.label}</a></li>
      ))}
    </ul>

    <!-- mobile: simple stacked link row, no hamburger complexity for v1 -->
    <ul class="flex md:hidden items-center gap-3 text-xs text-[var(--color-slate)] overflow-x-auto">
      {[...leftLinks, ...rightLinks].map((link) => (
        <li class="shrink-0"><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
  </nav>
</header>
