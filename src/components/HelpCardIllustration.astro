---
// PLACEHOLDER ILLUSTRATIONS — stand-ins for mockup6's photographic/illustrative
// cards, pending real brand assets. Swap the <svg> markup per `kind` for the
// final artwork when it's ready; the surrounding card markup can stay as-is.
interface Props {
  kind: "strategy" | "content" | "campaigns" | "insight" | "automation" | "support";
}
const { kind } = Astro.props as Props;
---
<div class="w-full aspect-[4/3] bg-white flex items-center justify-center overflow-hidden">
  {kind === "strategy" && (
    <svg width="88" height="88" viewBox="0 0 88 88" fill="none">
      <circle cx="40" cy="46" r="20" fill="var(--color-paper)" stroke="var(--color-slate-light)" stroke-width="1.5" />
      <circle cx="40" cy="46" r="12" fill="none" stroke="var(--color-slate-light)" stroke-width="1.5" />
      <circle cx="40" cy="46" r="4" fill="var(--color-accent)" />
      <path d="M58 18 L40 46" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" />
      <path d="M58 18 l-8 1.5 M58 18 l1.5 8" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M50 30 L40 46" stroke="var(--color-ink)" stroke-width="1.5" stroke-linecap="round" />
      <path d="M50 30 l-7 0 M50 30 l0 7" stroke="var(--color-ink)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )}
  {kind === "content" && (
    <svg width="92" height="92" viewBox="0 0 92 92" fill="none">
      <rect x="16" y="18" width="60" height="40" rx="3" fill="var(--color-paper)" stroke="var(--color-slate-light)" stroke-width="1.5" />
      <rect x="21" y="23" width="20" height="14" rx="2" fill="var(--color-accent-soft)" />
      <circle cx="27" cy="29" r="3" fill="var(--color-accent)" />
      <path d="M46 26 h24 M46 32 h18" stroke="var(--color-slate-light)" stroke-width="1.5" stroke-linecap="round" />
      <path d="M21 46 h50 M21 51 h34" stroke="var(--color-line)" stroke-width="1.5" stroke-linecap="round" />
      <path d="M36 64 h20" stroke="var(--color-ink)" stroke-width="1.5" stroke-linecap="round" />
      <path d="M42 58 v6 M50 58 v6" stroke="var(--color-ink)" stroke-width="1.5" />
    </svg>
  )}
  {kind === "campaigns" && (
    <svg width="92" height="92" viewBox="0 0 92 92" fill="none">
      <rect x="16" y="38" width="26" height="26" rx="2" fill="var(--color-accent-soft)" stroke="var(--color-accent)" stroke-width="1.5" />
      <path d="M16 46 h26" stroke="var(--color-accent)" stroke-width="1.5" />
      <path d="M29 38 v-5 l4.5 4.5 l-4.5 4.5 l-4.5 -4.5 z" fill="var(--color-accent)" stroke="var(--color-accent)" stroke-linejoin="round" />
      <rect x="48" y="26" width="26" height="36" rx="2" fill="var(--color-paper)" stroke="var(--color-slate-light)" stroke-width="1.5" />
      <path d="M48 35 h26" stroke="var(--color-line)" stroke-width="1.5" stroke-dasharray="2 3" />
      <path d="M55 45 h12 M55 51 h12 M55 57 h8" stroke="var(--color-slate-light)" stroke-width="1.5" stroke-linecap="round" />
    </svg>
  )}
  {kind === "insight" && (
    <svg width="88" height="88" viewBox="0 0 88 88" fill="none">
      <path d="M32 58 v-12 M42 58 v-20 M52 58 v-8 M62 58 v-16" stroke="var(--color-accent)" stroke-width="4" stroke-linecap="round" />
      <circle cx="38" cy="36" r="17" fill="none" stroke="var(--color-ink)" stroke-width="1.5" />
      <path d="M50 48 L62 60" stroke="var(--color-ink)" stroke-width="1.5" stroke-linecap="round" />
    </svg>
  )}
  {kind === "automation" && (
    <svg width="88" height="88" viewBox="0 0 88 88" fill="none">
      <circle cx="34" cy="36" r="17" fill="none" stroke="var(--color-slate-light)" stroke-width="1.5" />
      <path d="M34 19 A17 17 0 0 1 51 36 L34 36 Z" fill="var(--color-accent)" opacity="0.85" />
      <path d="M34 36 L34 19" stroke="var(--color-paper)" stroke-width="1" />
      <path d="M55 60 v-18 M63 60 v-26 M71 60 v-10" stroke="var(--color-ink)" stroke-width="4" stroke-linecap="round" />
      <path d="M51 60 h26" stroke="var(--color-line)" stroke-width="1.5" stroke-linecap="round" />
    </svg>
  )}
  {kind === "support" && (
    <svg width="92" height="92" viewBox="0 0 92 92" fill="none">
      <path d="M18 26 h38 a5 5 0 0 1 5 5 v16 a5 5 0 0 1 -5 5 h-19 l-9 9 v-9 h-10 a5 5 0 0 1 -5 -5 v-16 a5 5 0 0 1 5 -5 z"
        fill="var(--color-accent-soft)" stroke="var(--color-accent)" stroke-width="1.5" stroke-linejoin="round" />
      <path d="M27 38 h22 M27 45 h14" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" />
      <path d="M52 52 h20 a4 4 0 0 1 4 4 v10 a4 4 0 0 1 -4 4 h-6 l-6 6 v-6 h-8 a4 4 0 0 1 -4 -4 v-10 a4 4 0 0 1 4 -4 z"
        fill="var(--color-paper)" stroke="var(--color-slate-light)" stroke-width="1.5" stroke-linejoin="round" />
      <circle cx="60" cy="62" r="1.6" fill="var(--color-slate-light)" />
      <circle cx="66" cy="62" r="1.6" fill="var(--color-slate-light)" />
      <circle cx="72" cy="62" r="1.6" fill="var(--color-slate-light)" />
    </svg>
  )}
</div>
