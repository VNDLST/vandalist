---
interface Props {
  icon: "circle" | "triangle" | "square" | "star" | "hexagon" | "pentagon";
}
const { icon } = Astro.props;

// Each shape gets its own distinct vivid gradient, matching the reference
// mockup's plain solid-gradient geometric shapes (no badge container, no
// inner glyph).
const gradients: Record<Props["icon"], [string, string]> = {
  circle: ["#8a6ce8", "#6a9ce8"],
  triangle: ["#e83f3f", "#e8467c"],
  square: ["#6ee8c2", "#4696e8"],
  star: ["#4696e8", "#e8d646"],
  hexagon: ["#e8467c", "#8a46c2"],
  pentagon: ["#8ac2e8", "#e8a7e0"],
};

const shapes: Record<Props["icon"], string> = {
  circle: '<circle cx="32" cy="32" r="30" fill="url(#g)"/>',
  triangle: '<polygon points="32,60 3,4 61,4" fill="url(#g)"/>',
  square: '<rect x="4" y="4" width="56" height="56" rx="4" fill="url(#g)"/>',
  star: '<polygon points="32,2 41,23 64,23 45,37 52,60 32,47 12,60 19,37 0,23 23,23" fill="url(#g)"/>',
  hexagon: '<polygon points="32,2 59,17 59,47 32,62 5,47 5,17" fill="url(#g)"/>',
  pentagon: '<polygon points="32,2 61,24 50,58 14,58 3,24" fill="url(#g)"/>',
};

const [from, to] = gradients[icon];
---
<svg width="64" height="64" viewBox="0 0 64 64" class="shrink-0">
  <defs>
    <linearGradient id={`g-${icon}`} x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color={from} />
      <stop offset="100%" stop-color={to} />
    </linearGradient>
  </defs>
  <Fragment set:html={shapes[icon].replace('url(#g)', `url(#g-${icon})`)} />
</svg>
