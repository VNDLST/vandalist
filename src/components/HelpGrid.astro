---
import HelpCardIllustration from "./HelpCardIllustration.astro";
import SectionHeading from "./SectionHeading.astro";

const items: { kind: Parameters<typeof HelpCardIllustration>[0]["kind"]; title: string; text: string }[] = [
  { kind: "1", title: "Marketing & Campaigns", text: "Launch with purpose, then build systems that compound results." },
  { kind: "2", title: "Connected Marketing Services", text: "All your channels and functions, working from one connected strategy." },
  { kind: "3", title: "Website Design & Optimisation", text: "Design and optimise a site built to convert and perform." },
  { kind: "4", title: "Strategy & Direction", text: "Align on what matters, who it's for, and how we'll win." },
  { kind: "5", title: "SEO & Search Visibility", text: "Improve visibility and get found by the right people in search." },
  { kind: "6", title: "Analytics & Reporting", text: "Turn data and customer insights into clearer direction." },
];
---
<section class="max-w-7xl mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-16 md:pb-24">
  <SectionHeading
    eyebrow="How we help in practice"
    heading="Marketing rarely arrives as a neat, isolated project"
    subtext="It's a mix of planning, building, improving, and responding to opportunities as they arise."
  />

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {items.map((item, i) => (
      <div class="rounded-[var(--radius-card)] border border-[var(--color-slate-light)]/30 bg-white p-5 flex items-center gap-4">
        <HelpCardIllustration kind={item.kind} />
        <div>
          <p class="font-semibold text-[var(--color-ink)] text-sm mb-1">{i + 1}. {item.title}</p>
          <p class="text-[var(--color-slate)] text-sm leading-relaxed">{item.text}</p>
        </div>
      </div>
    ))}
  </div>
</section>
