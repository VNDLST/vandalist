---
const rows = [
  { inhouse: "Full-time salary + benefits", vandalist: "Fractional team with senior expertise" },
  { inhouse: "Rare, generalist expertise", vandalist: "Flexible, cross-functional support" },
  { inhouse: "Months to onboard & ramp", vandalist: "Plug in quickly, scale as needed" },
  { inhouse: "Tooling, software, and training", vandalist: "Right tools, right team, right now" },
  { inhouse: "Vacancy risk and turnover", vandalist: "Predictable pricing, fewer overheads" },
  { inhouse: "Siloed focus and org complexity", vandalist: "Outcome-focused, aligned to results" },
];
---
<section class="max-w-6xl mx-auto px-6 md:px-10 py-10">
  <div class="rounded-[var(--radius-card)] bg-[var(--color-paper-dim)] p-6 md:py-10 md:px-16">
    <div class="grid md:grid-cols-[1fr_2fr] gap-8 items-start">
      <div>
        <p class="text-sm tracking-wide text-[var(--color-accent)] font-medium mb-3">Coverage without hiring</p>
        <h2 class="text-2xl md:text-3xl font-semibold mb-4">Capabilities without the headcount</h2>
        <p class="text-[var(--color-slate)] mb-4">Everything you need&mdash;without the overhead, hiring risk, or ramp time.</p>
        <a href="#" class="text-[var(--color-accent)] text-sm font-medium inline-flex items-center gap-1">
          Explore how it works <span aria-hidden="true">&rarr;</span>
        </a>
      </div>

      <div class="bg-white border border-[var(--color-paper-dim)] rounded-[var(--radius-card)] overflow-hidden shadow-[0_20px_45px_-15px_rgba(28,27,26,0.15)]">
        <div class="grid grid-cols-2 divide-x divide-[var(--color-line)] items-center px-6 md:px-8 py-4 border-b border-[var(--color-line)]">
          <p class="font-semibold text-sm text-center">Hiring In-House</p>
          <p class="font-semibold text-sm text-[var(--color-accent)] text-center whitespace-nowrap">Working with Vandalist</p>
        </div>
        {rows.map((row, i) => (
          <div
            class:list={[
              "grid grid-cols-2 divide-x divide-[var(--color-line)] items-center px-6 md:px-8 py-4",
              i < rows.length - 1 ? "border-b border-[var(--color-line)]" : "",
            ]}
          >
            <p class="text-sm text-[var(--color-slate)] text-center pr-4">{row.inhouse}</p>
            <p class="text-sm text-[var(--color-ink)] text-center pl-4">{row.vandalist}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
