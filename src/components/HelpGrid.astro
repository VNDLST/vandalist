---
import HelpCardIllustration from "./HelpCardIllustration.astro";

const items: { kind: Parameters<typeof HelpCardIllustration>[0]["kind"]; title: string; text: string }[] = [
  { kind: "strategy", title: "Commerce Strategy", text: "Align on what matters, who it's for, and how we'll win." },
  { kind: "content", title: "Position & Contentcraft", text: "Sharpen your message and create content that earns attention." },
  { kind: "campaigns", title: "Campaigns & Systems", text: "Launch with purpose, then build systems that compound results." },
  { kind: "insight", title: "Insight & Analytics", text: "Turn data and customer insights into clearer direction." },
  { kind: "automation", title: "Marketing Operations & Automation", text: "Streamline workflows and automate the right things." },
  { kind: "support", title: "Ongoing Strategy & Support", text: "Stay agile with ongoing strategy and hands-on support." },
];
---
<section class="max-w-5xl mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-4 md:pb-6">
  <div class="mb-12 max-w-3xl">
    <p class="text-sm tracking-wide text-[var(--color-accent)] font-medium mb-3">How We Help in Practice</p>
    <h2 class="text-2xl md:text-3xl font-semibold mb-4 whitespace-nowrap">Marketing rarely arrives as a neat, isolated project.</h2>
    <p class="text-[var(--color-slate)]">
      It's a mix of planning, building, improving, and responding to opportunities as they arise.
    </p>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {items.map((item, i) => (
      <div class="rounded-[var(--radius-card)] border border-[var(--color-line)] bg-white overflow-hidden">
        <HelpCardIllustration kind={item.kind} />
        <div class="p-5">
          <p class="font-semibold text-[var(--color-ink)] text-sm mb-1">{i + 1}. {item.title}</p>
          <p class="text-[var(--color-slate)] text-sm leading-relaxed">{item.text}</p>
        </div>
      </div>
    ))}
  </div>
</section>
