---
const logos = [
  { file: "Kestral.jpg", name: "Kestral" },
  { file: "Archie-Hardware.jpg", name: "Archie Hardware" },
  { file: "Matilda-Veneer.jpg", name: "Matilda Veneer" },
  { file: "Berlitz.jpg", name: "Berlitz" },
  { file: "chrc.jpg", name: "CHRC" },
  { file: "busy.jpg", name: "The BUSY Group" },
  { file: "Ready-Fund-Grow.jpg", name: "Ready Fund Grow" },
  { file: "Zzzopa.jpg", name: "Zzzopa" },
  { file: "sonic.jpg", name: "Sonic" },
  { file: "littlewishes.jpg", name: "Little Wishes" },
  { file: "ACADS-BSG-1.jpg", name: "ACADS-BSG" },
  { file: "ME.jpg", name: "ME" },
  { file: "Aryon.jpg", name: "Aryon" },
  { file: "Rethink-Group.jpg", name: "Rethink Group" },
  { file: "Tandm.jpg", name: "Tandm" },
];
---
<section class="max-w-6xl mx-auto px-6 md:px-10 py-12 md:py-16">
  <div class="flex flex-col gap-8">
    {[logos.slice(0, 8), logos.slice(8)].map((row) => (
      <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-6">
        {row.map((logo) => (
          <img
            src={`${import.meta.env.BASE_URL}/client-logos/${logo.file}`}
            alt={logo.name}
            class="h-7 md:h-8 w-auto object-contain grayscale opacity-50 hover:opacity-80 transition-opacity"
          />
        ))}
      </div>
    ))}
  </div>
</section>
