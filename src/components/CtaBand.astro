---
---
<section class="relative z-10 max-w-5xl mx-auto px-6 md:px-10 pb-0">
  <div class="relative rounded-[var(--radius-card)] overflow-hidden bg-[var(--color-paper-dim)] shadow-[0_25px_60px_-15px_rgba(232,70,124,0.35)]">
    <svg
      class="absolute inset-0 w-full h-full"
      viewBox="0 0 800 200"
      preserveAspectRatio="xMidYMid slice"
      aria-hidden="true"
    >
      <rect width="800" height="200" fill="#ede6de" />
      <polygon points="560,200 660,200 610,30" fill="#d8c3ad" />
      <polygon points="610,200 700,200 660,70" fill="#e9d9c4" />
      <polygon points="660,200 800,200 740,15" fill="#f4ede2" />
      <polygon points="700,200 800,200 800,90" fill="#c9b195" />
    </svg>
    <div class="relative z-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 px-6 md:px-10 py-6 md:py-8">
      <div>
        <p class="text-sm tracking-wide text-[var(--color-accent)] font-medium mb-1">Tell us about it</p>
        <h2 class="text-xl md:text-2xl font-semibold text-[var(--color-ink)] mb-1">Brain dump or itemised requirements</h2>
        <p class="text-[var(--color-slate)] text-sm">We will provide the quote, guidance, or direction you are looking for.</p>
      </div>
      <a
        href="/contact"
        class="inline-flex items-center gap-4 rounded-2xl bg-[var(--color-paper)] border border-[var(--color-line)] px-7 py-4 text-base text-[var(--color-ink)] hover:border-[var(--color-slate)] transition-colors shrink-0"
      >
        <span
          class="w-8 h-8 rounded-full shrink-0 ring-2 ring-white"
          style="background: radial-gradient(circle at 35% 30%, #f2789a 0%, var(--color-accent) 60%, #c72f5e 100%); box-shadow: 0 0 14px 3px rgba(232, 70, 124, 0.5);"
        ></span>
        How can we help?
      </a>
    </div>
  </div>
</section>
