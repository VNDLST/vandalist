---
import SectionHeading from "./SectionHeading.astro";

const rows = [
  { inhouse: "Full-time salary + benefits", vandalist: "Fractional team with senior expertise" },
  { inhouse: "Rare, generalist expertise", vandalist: "Flexible, cross-functional support" },
  { inhouse: "Months to onboard & ramp", vandalist: "Plug in quickly, scale as needed" },
  { inhouse: "Tooling, software, and training", vandalist: "Right tools, right team, right now" },
  { inhouse: "Vacancy risk and turnover", vandalist: "Predictable pricing, fewer overheads" },
  { inhouse: "Siloed focus and org complexity", vandalist: "Outcome-focused, aligned to results" },
];
---
<section class="max-w-5xl mx-auto px-6 md:px-10 pt-4 md:pt-6 pb-4 md:pb-6">
  <SectionHeading
    eyebrow="Coverage Without Hiring"
    heading="Marketing capabilities without the headcount."
    subtext="Lorem ipsum dolor sit amet, consectetur adipiscing elit."
    align="center"
    maxWidth="max-w-2xl"
  />

  <div class="bg-white border border-[var(--color-line)] rounded-[var(--radius-card)] overflow-hidden">
    <div class="grid grid-cols-[1fr_auto_1fr] items-center px-6 md:px-10 py-4 border-b border-[var(--color-line)]">
      <p class="font-semibold text-center">Hiring In-House</p>
      <span class="w-8 flex justify-center text-[var(--color-line)]" aria-hidden="true">+</span>
      <p class="font-semibold text-center text-[var(--color-accent)]">Working with Vandalist</p>
    </div>
    {rows.map((row, i) => (
      <div
        class:list={[
          "grid grid-cols-[1fr_auto_1fr] items-center px-6 md:px-10 py-4",
          i < rows.length - 1 ? "border-b border-[var(--color-line)]" : "",
        ]}
      >
        <p class="text-center text-[var(--color-slate)]">{row.inhouse}</p>
        <span class="w-8 flex justify-center">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5">
            <circle cx="12" cy="12" r="9.5" />
            <path d="M9 9 L15 15 M15 9 L9 15" stroke-linecap="round" />
          </svg>
        </span>
        <p class="text-center text-[var(--color-ink)]">{row.vandalist}</p>
      </div>
    ))}
  </div>
</section>
