---
import PillButton from "./PillButton.astro";
---
<section class="max-w-6xl mx-auto px-6 md:px-10 pb-16 md:pb-24">
  <div class="relative rounded-[var(--radius-card)] overflow-hidden bg-[var(--color-paper-dim)]">
    <div class="relative z-10 p-8 md:p-14 max-w-md">
      <h2 class="text-2xl md:text-3xl font-semibold text-[var(--color-ink)] mb-3">Ready to work smarter, not bigger?</h2>
      <p class="text-[var(--color-slate)] mb-6">Let's build a marketing engine that drives growth and makes your life easier.</p>
      <PillButton href="#" variant="primary">
        Let's discuss your strategy <span aria-hidden="true" class="ml-1">→</span>
      </PillButton>
    </div>
    <svg
      class="absolute top-0 right-0 h-full w-1/2 hidden sm:block"
      viewBox="0 0 400 260"
      preserveAspectRatio="xMidYMid slice"
      aria-hidden="true"
    >
      <rect width="400" height="260" fill="#ede6de" />
      <polygon points="120,260 260,260 190,40" fill="#d8c3ad" />
      <polygon points="190,260 300,260 245,90" fill="#e9d9c4" />
      <polygon points="260,260 400,260 330,20" fill="#f4ede2" />
      <polygon points="300,260 400,260 400,120" fill="#c9b195" />
    </svg>
  </div>
</section>
