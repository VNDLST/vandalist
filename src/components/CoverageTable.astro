---
const rows = [
  { label: "Full-time salary + benefits", vandalist: "Fractional team with senior expertise" },
  { label: "Rare, generalist expertise", vandalist: "Flexible, cross-functional support" },
  { label: "Months to onboard & ramp", vandalist: "Plug in quickly, scale as needed" },
  { label: "Tooling, software, and training", vandalist: "Right tools, right team, right now" },
  { label: "Vacancy risk and turnover", vandalist: "Predictable pricing, fewer overheads" },
  { label: "Siloed focus and org complexity", vandalist: "Outcome-focused, aligned to results" },
];
---
<section class="max-w-5xl mx-auto px-6 md:px-10 pt-4 md:pt-6 pb-4 md:pb-6">
  <div class="rounded-[var(--radius-card)] bg-[var(--color-paper-dim)] p-6 md:p-10">
    <div class="grid md:grid-cols-[minmax(0,1fr)_minmax(0,1.5fr)] gap-8 items-start">
      <div>
        <p class="text-sm tracking-wide text-[var(--color-accent)] font-medium mb-3">Coverage without hiring</p>
        <h2 class="text-2xl md:text-3xl font-semibold mb-4">Marketing capabilities without the headcount</h2>
        <p class="text-[var(--color-slate)] mb-4">Everything you need&mdash;without the overhead, hiring risk, or ramp time.</p>
        <a href="#" class="text-[var(--color-accent)] text-sm font-medium inline-flex items-center gap-1">
          Explore how it works <span aria-hidden="true">&rarr;</span>
        </a>
      </div>

      <div class="bg-white border border-[var(--color-line)] rounded-[var(--radius-card)] overflow-hidden">
        <div class="grid grid-cols-[1.1fr_auto_1.4fr] items-center px-6 md:px-8 py-4 border-b border-[var(--color-line)] gap-3">
          <p class="font-semibold text-sm">What you get</p>
          <p class="font-semibold text-sm text-center whitespace-nowrap">Hiring In-House</p>
          <p class="font-semibold text-sm text-[var(--color-accent)] whitespace-nowrap">Working with Vandalist</p>
        </div>
        {rows.map((row, i) => (
          <div
            class:list={[
              "grid grid-cols-[1.1fr_auto_1.4fr] items-center px-6 md:px-8 py-4 gap-3",
              i < rows.length - 1 ? "border-b border-[var(--color-line)]" : "",
            ]}
          >
            <p class="text-sm text-[var(--color-slate)]">{row.label}</p>
            <span class="w-8 flex justify-center">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-slate-light)" stroke-width="1.5">
                <circle cx="12" cy="12" r="9.5" />
                <path d="M9 9 L15 15 M15 9 L9 15" stroke-linecap="round" />
              </svg>
            </span>
            <p class="text-sm text-[var(--color-ink)]">{row.vandalist}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
