---
import PillButton from "./PillButton.astro";
---
<section class="max-w-6xl mx-auto px-6 md:px-10 pt-12 pb-20 md:pt-16 md:pb-28 grid md:grid-cols-2 gap-10 items-center">
  <div>
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.05] mb-6">
      Marketing strategy, execution, and support
    </h1>
    <p class="text-lg text-[var(--color-slate)] max-w-md mb-8">
      The brains to plan. The skills to deliver. The structure to support.
    </p>
    <PillButton href="/contact">Let's discuss your strategy</PillButton>
  </div>

  <div class="relative hidden md:flex items-center justify-center h-80">
    <svg viewBox="0 0 320 280" class="w-full h-full max-w-sm" aria-hidden="true">
      <rect x="30" y="150" width="90" height="70" rx="6" fill="var(--color-paper-dim)" stroke="var(--color-line)" />
      <circle cx="230" cy="90" r="45" fill="none" stroke="var(--color-accent)" stroke-width="3" />
      <rect x="160" y="130" width="70" height="90" rx="8" fill="var(--color-ink)" opacity="0.06" />
      <line x1="120" y1="185" x2="230" y2="100" stroke="var(--color-line)" stroke-width="2" stroke-dasharray="4 6" />
      <circle cx="120" cy="185" r="6" fill="var(--color-accent)" />
      <circle cx="230" cy="185" r="6" fill="var(--color-ink)" opacity="0.4" />
    </svg>
  </div>
</section>
