---
import SectionHeading from "./SectionHeading.astro";

const steps = [
  { num: "01", title: "Discover & Prioritize", text: "We learn your business, market, and goals." },
  { num: "02", title: "Plan & Map the Work", text: "We define the strategy and roadmap." },
  { num: "03", title: "Execute & Optimise", text: "We build, launch, and iterate with focus." },
  { num: "04", title: "Report & Refine", text: "We measure what matters and keep improving." },
];

const weAre = [
  "Practical strategy partners",
  "Hands-on executors",
  "Flexible and responsive",
  "Results-focused",
];
const weArent = [
  "One-size-fits-all vendors",
  "People who disappear",
  "Jargon or vanity metrics",
  "Bloated retainers or lock-ins",
];

// Shimmer cycle: one arrow lit at a time, left to right, looping.
// Total loop = steps.length * SLICE seconds; each arrow's keyframe window
// is the first quarter of its own (offset) cycle, silent the rest.
const SLICE = 1.6;
const CYCLE = SLICE * (steps.length - 1);
---
<section class="max-w-[1400px] mx-auto px-6 md:px-12 lg:px-16 py-10">
  <div class="rounded-[var(--radius-card)] bg-[var(--color-paper-dim)] p-6 md:py-10 md:px-16">
    <div class="max-w-7xl mx-auto">
    <SectionHeading
      eyebrow="How we work"
      heading="Thoughtful, practical, and responsive"
      subtext="We align with your priorities, deadlines, and the way you like to work."
    />

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-y-10 gap-x-6 mb-12">
      {steps.map((step, i) => (
        <div class="flex flex-col items-center text-center relative">
          <div class="w-16 h-16 rounded-full border border-[var(--color-accent)] flex items-center justify-center mb-4 bg-[var(--color-paper)] relative z-10">
            {i === 0 && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5">
                <circle cx="11" cy="11" r="7" />
                <path d="M21 21 L16 16" stroke-linecap="round" />
              </svg>
            )}
            {i === 1 && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5">
                <path d="M5 19 L10 8 L14 14 L19 5" stroke-linecap="round" stroke-linejoin="round" />
                <circle cx="19" cy="5" r="1.6" fill="var(--color-accent)" stroke="none" />
                <path d="M5 19 l3 -1 M5 19 l1 -3" stroke-linecap="round" />
              </svg>
            )}
            {i === 2 && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5">
                <path d="M5 19 v-4 M11 19 v-9 M17 19 v-6" stroke-linecap="round" />
              </svg>
            )}
            {i === 3 && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5">
                <path d="M4 6 h13 a3 3 0 0 1 3 3 v6 a3 3 0 0 1 -3 3 h-8 l-5 4 v-4 h-0 a3 3 0 0 1 -3 -3 v-6 a3 3 0 0 1 3 -3 z" stroke-linejoin="round" />
              </svg>
            )}
          </div>
          <p class="text-xs font-semibold text-[var(--color-accent)] mb-1">{step.num}</p>
          <p class="font-semibold text-[var(--color-ink)] mb-1">{step.title}</p>
          <p class="text-sm text-[var(--color-slate)]">{step.text}</p>
          {i < steps.length - 1 && (
            <div class="arrow-track hidden lg:block absolute top-8 left-[calc(50%+40px)] w-[calc(100%-80px)] h-[2px]" aria-hidden="true">
              <div class="h-full w-full arrow-base"></div>
              <div class="shimmer" style={`animation-delay:${i * SLICE}s`}></div>
              <span class="arrowhead"></span>
            </div>
          )}
        </div>
      ))}
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="rounded-[var(--radius-card)] border border-[#cfe8d4] bg-[#f3faf4] shadow-[0_20px_45px_-15px_rgba(28,27,26,0.15)] p-6 md:p-8">
        <div class="flex items-center gap-4 pb-5 border-b border-[#dcefe0]">
          <div class="w-12 h-12 rounded-full bg-[#e2f3e5] flex items-center justify-center shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2f8f4e" stroke-width="1.75">
              <circle cx="12" cy="8" r="3.2" />
              <path d="M5 20c0-3.3 3-5.8 7-5.8s7 2.5 7 5.8" stroke-linecap="round" />
            </svg>
          </div>
          <div>
            <p class="text-xl font-semibold text-[#2f8f4e]">What we are</p>
            <p class="text-sm text-[var(--color-slate)]">How we show up</p>
          </div>
        </div>
        <ul>
          {weAre.map((item, i) => (
            <li class:list={["flex items-center gap-3 py-4", i < weAre.length - 1 && "border-b border-[#dcefe0]"]}>
              <span class="w-6 h-6 rounded-full bg-[#2f8f4e] flex items-center justify-center shrink-0">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3">
                  <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <span class="text-[var(--color-ink)]">{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-[var(--radius-card)] border border-[#f6cddb] bg-[#fdf1f5] p-6 md:p-8">
        <div class="flex items-center gap-4 pb-5 border-b border-[#f7dbe4]">
          <div class="w-12 h-12 rounded-full bg-[#fbdfe8] flex items-center justify-center shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.75">
              <path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z" stroke-linejoin="round" />
              <path d="M9.5 9.5l5 5M14.5 9.5l-5 5" stroke-linecap="round" />
            </svg>
          </div>
          <div>
            <p class="text-xl font-semibold text-[var(--color-accent)]">What we aren't</p>
            <p class="text-sm text-[var(--color-slate)]">What we avoid</p>
          </div>
        </div>
        <ul>
          {weArent.map((item, i) => (
            <li class:list={["flex items-center gap-3 py-4", i < weArent.length - 1 && "border-b border-[#f7dbe4]"]}>
              <span class="w-6 h-6 rounded-full flex items-center justify-center shrink-0" style="background:#ff3d6b">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3">
                  <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" />
                </svg>
              </span>
              <span class="text-[var(--color-ink)]">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
    </div>
  </div>
</section>

<style define:vars={{ cycle: `${CYCLE}s` }}>
  .arrow-base {
    background: repeating-linear-gradient(
      to right,
      var(--color-line) 0,
      var(--color-line) 4px,
      transparent 4px,
      transparent 8px
    );
  }
  .shimmer {
    position: absolute;
    inset: 0;
    width: 30%;
    background: linear-gradient(to right, transparent, var(--color-accent), transparent);
    opacity: 0;
    transform: translateX(-120%);
    animation: shimmer-sweep var(--cycle) linear infinite;
  }
  .arrowhead {
    position: absolute;
    right: -1px;
    top: 50%;
    width: 7px;
    height: 7px;
    border-top: 2px solid var(--color-line);
    border-right: 2px solid var(--color-line);
    transform: translateY(-50%) rotate(45deg);
  }
  @keyframes shimmer-sweep {
    0% { transform: translateX(-120%); opacity: 0; }
    1% { opacity: 1; }
    10% { opacity: 1; transform: translateX(400%); }
    11%, 100% { opacity: 0; transform: translateX(400%); }
  }
</style>
