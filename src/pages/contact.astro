---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const projectStages = ["Urgent", "Assessing options", "Future planning", "Not sure yet"];
---
<Layout title="Contact">
  <div class="bg-[var(--color-paper-dim)]">
    <Header />

    <div class="max-w-7xl mx-auto px-6 md:px-10 pb-6 md:pb-10">
      <div class="md:max-w-[50%]">
        <p class="text-sm tracking-wide text-[var(--color-accent)] font-medium mb-3">Contact</p>
        <h1 class="text-4xl md:text-5xl font-semibold leading-[1.05] tracking-[-0.02em] mb-4">
          Tell us what you need help with
        </h1>
        <p class="text-[var(--color-slate)] max-w-md mb-12">
          Send through the details, even if the brief is still taking shape.
        </p>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 md:px-10 pb-20 md:pb-28">
      <div class="grid lg:grid-cols-[1fr_380px] gap-6 items-start">
        <!-- Form -->
        <form class="rounded-[var(--radius-card)] bg-white p-6 md:p-8 shadow-[0_20px_45px_-15px_rgba(28,27,26,0.15)]">
          <div class="grid sm:grid-cols-2 gap-5 mb-5">
            <div>
              <label for="name" class="block text-sm font-semibold text-[var(--color-ink)] mb-2">Name</label>
              <input
                id="name"
                type="text"
                placeholder="Your name"
                class="w-full rounded-lg border border-[var(--color-line)] px-4 py-3 text-sm text-[var(--color-ink)] placeholder:text-[var(--color-slate-light)] focus:outline-none focus:border-[var(--color-slate)]"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold text-[var(--color-ink)] mb-2">Email</label>
              <input
                id="email"
                type="email"
                placeholder="you@example.com"
                class="w-full rounded-lg border border-[var(--color-line)] px-4 py-3 text-sm text-[var(--color-ink)] placeholder:text-[var(--color-slate-light)] focus:outline-none focus:border-[var(--color-slate)]"
              />
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-5 mb-5">
            <div>
              <label for="phone" class="block text-sm font-semibold text-[var(--color-ink)] mb-2">Phone</label>
              <input
                id="phone"
                type="tel"
                placeholder="e.g. 0412 345 678"
                class="w-full rounded-lg border border-[var(--color-line)] px-4 py-3 text-sm text-[var(--color-ink)] placeholder:text-[var(--color-slate-light)] focus:outline-none focus:border-[var(--color-slate)]"
              />
            </div>
            <div>
              <label for="business" class="block text-sm font-semibold text-[var(--color-ink)] mb-2">Business name</label>
              <input
                id="business"
                type="text"
                placeholder="Your business name"
                class="w-full rounded-lg border border-[var(--color-line)] px-4 py-3 text-sm text-[var(--color-ink)] placeholder:text-[var(--color-slate-light)] focus:outline-none focus:border-[var(--color-slate)]"
              />
            </div>
          </div>

          <div class="mb-5">
            <label for="stage" class="block text-sm font-semibold text-[var(--color-ink)] mb-2">Project stage</label>
            <div class="relative">
              <select
                id="stage"
                class="w-full appearance-none rounded-lg border border-[var(--color-line)] px-4 py-3 text-sm text-[var(--color-ink)] focus:outline-none focus:border-[var(--color-slate)] bg-white"
              >
                <option value="" selected disabled>Select an option</option>
                {projectStages.map((stage) => <option value={stage}>{stage}</option>)}
              </select>
              <svg
                class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2"
                width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-slate)" stroke-width="2"
              >
                <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
          </div>

          <div class="mb-6">
            <label for="details" class="block text-sm font-semibold text-[var(--color-ink)] mb-2">What do you need help with?</label>
            <textarea
              id="details"
              rows="4"
              placeholder="Share a few details about your project, goals, challenges or any questions you have."
              class="w-full rounded-lg border border-[var(--color-line)] px-4 py-3 text-sm text-[var(--color-ink)] placeholder:text-[var(--color-slate-light)] focus:outline-none focus:border-[var(--color-slate)] resize-y"
            ></textarea>
          </div>

          <button
            type="submit"
            class="inline-flex items-center gap-4 rounded-2xl bg-[var(--color-paper)] border border-[var(--color-line)] px-7 py-4 text-base text-[var(--color-ink)] hover:border-[var(--color-slate)] transition-colors mb-4"
          >
            <span
              class="w-8 h-8 rounded-full shrink-0 ring-2 ring-white"
              style="background: radial-gradient(circle at 35% 30%, #f2789a 0%, var(--color-accent) 60%, #c72f5e 100%); box-shadow: 0 0 14px 3px rgba(232, 70, 124, 0.5);"
            ></span>
            Send enquiry
          </button>

          <p class="text-xs text-[var(--color-slate-light)]">
            We respect your privacy. Your information will only be used to respond to your enquiry.
          </p>
        </form>

        <!-- Contact info -->
        <div class="rounded-[var(--radius-card)] bg-[var(--color-paper-dim)] p-3">
          <div class="aspect-square rounded-[calc(var(--radius-card)-0.3rem)] bg-[var(--color-paper)] p-6 mb-6 flex flex-col justify-center shadow-[0_20px_45px_-15px_rgba(28,27,26,0.15)]">
            <p class="font-semibold text-[var(--color-accent)] mb-2">Prefer to talk it through?</p>
            <p class="text-sm text-[var(--color-slate)] mb-5">Book a meeting and we can work out the right next step.</p>
            <a
              href="#"
              class="flex items-center justify-center gap-2 rounded-xl bg-[var(--color-paper-dim)] px-5 py-3.5 text-sm font-semibold text-[var(--color-accent)] hover:brightness-95 transition-all"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="4" y="5" width="16" height="16" rx="2" />
                <path d="M4 10h16M8 3v4M16 3v4" stroke-linecap="round" />
              </svg>
              Book a meeting
            </a>
          </div>

          <div class="space-y-5 px-3 pb-3">
            <div class="flex items-start gap-4 pb-5 border-b border-[var(--color-line)]">
              <span class="w-10 h-10 rounded-full bg-[var(--color-paper)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.75">
                  <rect x="3" y="5" width="18" height="14" rx="2" />
                  <path d="M3 6.5l9 6.5 9-6.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <div>
                <p class="font-semibold text-[var(--color-ink)] mb-0.5">Email</p>
                <a href="mailto:hello@vandalist.com.au" class="text-sm text-[var(--color-slate)] hover:text-[var(--color-ink)] transition-colors">hello@vandalist.com.au</a>
              </div>
            </div>

            <div class="flex items-start gap-4 pb-5 border-b border-[var(--color-line)]">
              <span class="w-10 h-10 rounded-full bg-[var(--color-paper)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.75">
                  <path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 5 5L14 13l5 2v3a2 2 0 0 1-2 2A15 15 0 0 1 3 6a2 2 0 0 1 2-2z" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <div>
                <p class="font-semibold text-[var(--color-ink)] mb-0.5">Phone</p>
                <p class="text-sm text-[var(--color-slate)]">07 3106 4754</p>
              </div>
            </div>

            <div class="flex items-start gap-4 pb-5 border-b border-[var(--color-line)]">
              <span class="w-10 h-10 rounded-full bg-[var(--color-paper)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.75">
                  <path d="M12 21s7-6.5 7-11.5A7 7 0 0 0 5 9.5C5 14.5 12 21 12 21z" stroke-linejoin="round" />
                  <circle cx="12" cy="9.5" r="2.3" />
                </svg>
              </span>
              <div>
                <p class="font-semibold text-[var(--color-ink)] mb-0.5">Address</p>
                <p class="text-sm text-[var(--color-slate)]">Vandalist<br />Cornubia, QLD<br />Australia</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <span class="w-10 h-10 rounded-full bg-[var(--color-paper)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.75">
                  <circle cx="12" cy="12" r="8.5" />
                  <path d="M12 7.5V12l3 2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <div>
                <p class="font-semibold text-[var(--color-ink)] mb-0.5">Response time</p>
                <p class="text-sm text-[var(--color-slate)]">We usually respond within one business day.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <Footer />
</Layout>
