---
---
<section class="relative z-10 bg-[var(--color-paper-dim)] border-t-2 border-[var(--color-paper-deep)]">
  <div class="max-w-3xl mx-auto px-6 md:px-10 py-16 md:py-20 text-center">
    <h2 class="text-2xl md:text-3xl font-semibold text-[var(--color-ink)] mb-4">Brain dump or itemised requirements</h2>
    <p class="text-[var(--color-slate)] mb-8">We will provide the quote, guidance, or direction you are looking for.</p>
    <a
      href="/contact"
      class="inline-flex items-center gap-4 rounded-2xl bg-[var(--color-paper)] border border-[var(--color-line)] px-7 py-4 text-base text-[var(--color-ink)] hover:border-[var(--color-slate)] transition-colors"
    >
      <span
        class="w-8 h-8 rounded-full shrink-0 ring-2 ring-white"
        style="background: radial-gradient(circle at 35% 30%, #f2789a 0%, var(--color-accent) 60%, #c72f5e 100%); box-shadow: 0 0 14px 3px rgba(232, 70, 124, 0.5);"
      ></span>
      How can we help?
    </a>
  </div>
</section>
