---
interface Props {
  currentPage?: string;
}
const { currentPage = "" } = Astro.props as Props;
const links = [
  { label: "Services", path: "/services" },
  { label: "Work", path: "/work" },
  { label: "Case Studies", path: "/case-studies" },
  { label: "How We Work", path: "/how-we-work" },
  { label: "About", path: "/about" },
  { label: "Contact", path: "/contact" },
];
const base = import.meta.env.BASE_URL;
---
<header class="w-full py-8 md:py-10">
  <nav class="max-w-7xl mx-auto px-6 md:px-10 flex items-center justify-between">
    <a href={base || "/"} class="shrink-0">
      <img src={`${base}/vandalist-logo.png`} alt="Vandalist" class="h-10 md:h-12 w-auto" />
    </a>

    <ul class="hidden md:flex items-center gap-8 text-sm text-[var(--color-slate)]">
      {links.map((link) => (
        <li class="relative">
          <a
            href={`${base}${link.path}`}
            class:list={[
              "transition-colors",
              currentPage === link.path ? "text-[var(--color-accent)] font-medium" : "hover:text-[var(--color-ink)]",
            ]}
          >
            {link.label}
          </a>
          {currentPage === link.path && (
            <span class="absolute left-1/2 -translate-x-1/2 -bottom-2 w-4 h-[2px] rounded-full bg-[var(--color-accent)]"></span>
          )}
        </li>
      ))}
    </ul>

    <!-- mobile: simple stacked link row, no hamburger complexity for v1 -->
    <ul class="flex md:hidden items-center gap-3 text-xs text-[var(--color-slate)] overflow-x-auto">
      {links.map((link) => (
        <li class="relative shrink-0">
          <a
            href={`${base}${link.path}`}
            class:list={currentPage === link.path ? "text-[var(--color-accent)] font-medium" : ""}
          >
            {link.label}
          </a>
          {currentPage === link.path && (
            <span class="absolute left-1/2 -translate-x-1/2 -bottom-1.5 w-3 h-[2px] rounded-full bg-[var(--color-accent)]"></span>
          )}
        </li>
      ))}
    </ul>
  </nav>
</header>
