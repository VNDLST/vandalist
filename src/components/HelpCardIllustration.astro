---
// Real client-supplied icons, replacing earlier placeholder SVGs.
interface Props {
  kind: "strategy" | "content" | "campaigns" | "insight" | "automation" | "support";
}
const { kind } = Astro.props as Props;
---
<div class="w-20 h-20 flex items-center justify-center shrink-0">
  <img
    src={`${import.meta.env.BASE_URL}/help-icons/${kind}.webp`}
    alt=""
    class="w-full h-full object-contain"
  />
</div>
