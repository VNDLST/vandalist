---
const columns = [
  {
    title: "Services",
    links: ["Strategy", "Content & Messaging", "Campaigns", "Automation", "Analytics & Reporting", "Ongoing Support"],
  },
  {
    title: "Company",
    links: ["About", "How We Work", "Case Studies", "Careers", "Contact"],
  },
  {
    title: "Resources",
    links: ["Magazine", "Guides", "Newsletter", "Tools", "Glossary"],
  },
];
---
<footer class="relative z-0 -mt-24 md:-mt-32 bg-[var(--color-paper-dim)]">
  <div class="max-w-5xl mx-auto px-6 md:px-10 pt-32 md:pt-44 pb-8">
    <div class="grid sm:grid-cols-2 lg:grid-cols-6 gap-10 mb-12">
      <div class="lg:col-span-2">
        <img src={`${import.meta.env.BASE_URL}/vandalist-logo.png`} alt="Vandalist" class="h-10 w-auto mb-4" />
        <p class="text-sm text-[var(--color-slate)] max-w-[220px]">
          Marketing strategy, execution, and support for ambitious businesses.
        </p>
      </div>
      {columns.map((col) => (
        <div>
          <p class="font-semibold text-sm text-[var(--color-ink)] mb-4">{col.title}</p>
          <ul class="space-y-2.5">
            {col.links.map((link) => (
              <li><a href="#" class="text-sm text-[var(--color-slate)] hover:text-[var(--color-ink)] transition-colors">{link}</a></li>
            ))}
          </ul>
        </div>
      ))}
      <div>
        <p class="font-semibold text-sm text-[var(--color-ink)] mb-4">Let's talk</p>
        <ul class="space-y-2.5 text-sm text-[var(--color-slate)]">
          <li><a href="mailto:hello@vandalist.com.au" class="hover:text-[var(--color-ink)] transition-colors">hello@vandalist.com.au</a></li>
          <li>07 3106 4754</li>
          <li>Cornubia, QLD</li>
        </ul>
      </div>
    </div>
    <div class="pt-6 border-t border-[var(--color-line)] flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-[var(--color-slate-light)]">
      <p>© 2026 Vandalist. All rights reserved.</p>
      <div class="flex items-center gap-6">
        <a href="#" class="hover:text-[var(--color-ink)] transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-[var(--color-ink)] transition-colors">Terms</a>
        <a href="#" class="hover:text-[var(--color-ink)] transition-colors">Cookies</a>
      </div>
    </div>
  </div>
</footer>
